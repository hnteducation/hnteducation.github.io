                "a": "<img src=\"https://asset.moon.vn/img/chat/large/2025/10/90a7e6c9-ef02-4b8c-9203-89719c0c6e75.jpg\" data-filename=\"\" style=\"max-width: 600px; height: auto;\">",
                "b": "<img src=\"https://asset.moon.vn/img/chat/large/2025/10/779eed07-ecad-4113-88d5-9a4572b03475.jpg\" data-filename=\"\" style=\"max-width: 600px; height: auto;\">",
                "c": "<img src=\"https://asset.moon.vn/img/chat/large/2025/10/33b254fb-7f26-4833-8da1-8934229294b7.jpg\" data-filename=\"\" style=\"max-width: 600px; height: auto;\">",
                "d": "<img src=\"https://asset.moon.vn/img/chat/large/2025/10/fdc0de37-e8e5-4405-8ed2-1d9151b5d1fc.jpg\" data-filename=\"\" style=\"max-width: 600px; height: auto;\">",
